{
  "uid": "cicd-stage-job-breakdown",
  "title": "CI/CD - Stage & Job Breakdown",
  "description": "Per-stage and per-job duration and status breakdown for a selected pipeline",
  "tags": ["cicd"],
  "timezone": "browser",
  "editable": true,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Stage Duration (seconds)",
      "type": "barchart",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "targets": [
        {
          "rawSql": "SELECT s.stage_name AS \"Stage\", ROUND(EXTRACT(EPOCH FROM (s.end_time - s.start_time))::numeric, 1) AS \"Duration (s)\" FROM stage_runs s JOIN pipeline_runs p ON s.pipeline_run_id = p.id WHERE p.pipeline_name = '$pipeline' AND p.run_no = $run_no AND s.end_time IS NOT NULL ORDER BY s.stage_order",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "groupWidth": 0.7,
        "barWidth": 0.5
      }
    },
    {
      "id": 2,
      "title": "Job Duration (seconds)",
      "type": "barchart",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "targets": [
        {
          "rawSql": "SELECT s.stage_name || ' / ' || j.job_name AS \"Job\", ROUND(EXTRACT(EPOCH FROM (j.end_time - j.start_time))::numeric, 1) AS \"Duration (s)\" FROM job_runs j JOIN stage_runs s ON j.stage_run_id = s.id JOIN pipeline_runs p ON s.pipeline_run_id = p.id WHERE p.pipeline_name = '$pipeline' AND p.run_no = $run_no AND j.end_time IS NOT NULL ORDER BY s.stage_order, j.job_name",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "groupWidth": 0.7,
        "barWidth": 0.5
      }
    },
    {
      "id": 3,
      "title": "Job Status Counts",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (status) (cicd_job_runs_total{pipeline=\"$pipeline\"})",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "SUCCESS" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "FAILED" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "legend": { "displayMode": "table", "placement": "right" },
        "pieType": "pie"
      }
    },
    {
      "id": 4,
      "title": "Job Results Table",
      "type": "table",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 10 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "targets": [
        {
          "rawSql": "SELECT s.stage_name AS \"Stage\", j.job_name AS \"Job\", j.status AS \"Status\", j.start_time AS \"Start Time\", j.end_time AS \"End Time\", CASE WHEN j.end_time IS NOT NULL AND j.start_time IS NOT NULL THEN ROUND(EXTRACT(EPOCH FROM (j.end_time - j.start_time))::numeric, 1) ELSE NULL END AS \"Duration (s)\" FROM job_runs j JOIN stage_runs s ON j.stage_run_id = s.id JOIN pipeline_runs p ON s.pipeline_run_id = p.id WHERE p.pipeline_name = '$pipeline' AND p.run_no = $run_no ORDER BY s.stage_order, j.job_name",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background", "mode": "basic" }
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "SUCCESS": { "color": "green", "text": "SUCCESS" } } },
                  { "type": "value", "options": { "FAILED": { "color": "red", "text": "FAILED" } } },
                  { "type": "value", "options": { "RUNNING": { "color": "yellow", "text": "RUNNING" } } }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "footer": { "show": false }
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" },
        "hide": 2
      },
      {
        "name": "DS_POSTGRESQL",
        "type": "datasource",
        "query": "postgres",
        "current": { "text": "PostgreSQL", "value": "PostgreSQL" },
        "hide": 2
      },
      {
        "name": "pipeline",
        "type": "query",
        "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
        "query": "SELECT DISTINCT pipeline_name FROM pipeline_runs ORDER BY pipeline_name",
        "refresh": 2,
        "sort": 1,
        "label": "Pipeline"
      },
      {
        "name": "run_no",
        "type": "query",
        "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
        "query": "SELECT DISTINCT run_no FROM pipeline_runs WHERE pipeline_name = '$pipeline' ORDER BY run_no DESC",
        "refresh": 2,
        "sort": 0,
        "label": "Run Number"
      }
    ]
  },
  "schemaVersion": 39,
  "version": 1
}
