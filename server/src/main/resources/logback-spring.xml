<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <springProfile name="!test">
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
      <encoder class="net.logstash.logback.encoder.LogstashEncoder">
        <includeMdcKeyName>pipeline</includeMdcKeyName>
        <includeMdcKeyName>run_no</includeMdcKeyName>
        <includeMdcKeyName>stage</includeMdcKeyName>
        <includeMdcKeyName>job</includeMdcKeyName>
        <includeMdcKeyName>source</includeMdcKeyName>
      </encoder>
    </appender>

    <appender name="OTEL" class="io.opentelemetry.instrumentation.logback.appender.v1_0.OpenTelemetryAppender">
      <captureExperimentalAttributes>true</captureExperimentalAttributes>
      <captureMdcAttributes>*</captureMdcAttributes>
    </appender>

    <root level="INFO">
      <appender-ref ref="CONSOLE"/>
      <appender-ref ref="OTEL"/>
    </root>
  </springProfile>

  <springProfile name="test">
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
      <encoder>
        <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
      </encoder>
    </appender>
    <root level="INFO">
      <appender-ref ref="CONSOLE"/>
    </root>
  </springProfile>
</configuration>
